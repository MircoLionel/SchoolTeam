APP_NAME="School Team Turismo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-backend.up.railway.app
APP_TIMEZONE=America/Argentina/Mendoza

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
# Railway provee DATABASE_URL; Laravel usa DB_URL/url internamente.
DATABASE_URL=
DB_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=schoolteam
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_SSLMODE=require

BCRYPT_ROUNDS=12

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_COOKIE=schoolteam_session
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,your-frontend.up.railway.app

CACHE_STORE=database
QUEUE_CONNECTION=database

TRUSTED_PROXIES=*
TRUSTED_PROXY_HEADERS=HEADER_X_FORWARDED_AWS_ELB
FORCE_HTTPS=true

CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.up.railway.app

# Almacenamiento recomendado para producción
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=

# Checkbook/PDFs
CHECKBOOK_TEMPLATE_PATH=
CHECKBOOK_OUTPUT_DIR=
RUN_MIGRATIONS=false
SEED_DEFAULT_USERS=false

# Frontend (service separado)
VITE_API_URL=https://your-backend.up.railway.app/api
